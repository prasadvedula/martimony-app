generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Gender {
  MALE
  FEMALE
}

enum Role {
  USER
  ADMIN
}

enum ProfileStatus {
  PENDING_CONSENT
  ACTIVE
  INACTIVE
  REJECTED
}

enum FamilyType {
  JOINT
  NUCLEAR
  EXTENDED
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  phone         String?   @unique
  passwordHash  String?
  name          String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  profile       Profile?  @relation("UserProfile")
  sessions      Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Profile {
  id              String        @id @default(cuid())
  userId          String?       @unique
  user            User?         @relation("UserProfile", fields: [userId], references: [id], onDelete: SetNull)

  // Basic
  name            String
  gender          Gender
  dateOfBirth     DateTime
  birthTime       String?
  birthPlace      String
  currentCity     String?
  currentState    String?

  // Hindu-specific
  caste           String
  subCaste        String?
  sakha           String?       // Brahmin Sakha (e.g., Rigveda Shakha)
  gotram          String?
  nakshatra       String        // Birth star
  rashi           String?       // Moon sign
  mangalDosha     Boolean       @default(false)
  kuladeviTemple  String?       // Kuldevi/Kuladeva

  // Surname
  surname         String?

  // Physical
  heightCm        Int?
  complexion      String?
  bodyType        String?

  // Professional
  education       String?
  educationDetail String?
  occupation      String?
  occupationDetail String?
  annualIncomeLpa Float?

  // Family
  fatherName      String?
  fatherOccupation String?
  motherName      String?
  motherOccupation String?
  siblings        String?
  familyType      FamilyType?
  familyValues    String?       // Traditional / Moderate / Liberal

  // Contact
  contactEmail    String?
  contactPhone    String?

  // Photo
  photoUrl        String?

  // Status & consent
  status          ProfileStatus @default(PENDING_CONSENT)
  consentGiven    Boolean       @default(false)
  consentToken    String?       @unique
  consentGivenAt  DateTime?

  // Upload source
  uploadedByAdmin Boolean       @default(false)
  pdfUploadBatch  String?

  // Preferences
  prefAgeMin      Int?
  prefAgeMax      Int?
  prefCastes      String[]      // e.g. ["Brahmin", "Kshatriya"]
  prefStates      String[]

  // Timestamps
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  matchesAsGroom  MatchRecord[] @relation("GroomProfile")
  matchesAsBride  MatchRecord[] @relation("BrideProfile")

  @@index([nakshatra])
  @@index([caste, subCaste])
  @@index([gender, status])
}

model MatchRecord {
  id              String    @id @default(cuid())
  groomProfileId  String
  brideProfileId  String
  totalScore      Int
  maxScore        Int       @default(36)
  scoreBreakdown  Json
  mangalStatus    String?
  recommendation  String?
  createdAt       DateTime  @default(now())

  groomProfile    Profile   @relation("GroomProfile", fields: [groomProfileId], references: [id], onDelete: Cascade)
  brideProfile    Profile   @relation("BrideProfile", fields: [brideProfileId], references: [id], onDelete: Cascade)

  @@unique([groomProfileId, brideProfileId])
}

model ConsentRequest {
  id          String    @id @default(cuid())
  token       String    @unique @default(cuid())
  profileId   String
  email       String?
  phone       String?
  status      String    @default("PENDING") // PENDING | ACCEPTED | REJECTED
  sentAt      DateTime  @default(now())
  respondedAt DateTime?
}
